#!/usr/bin/env zsh
#
# del
# Fuzzy git delete a remote branch if it exists.
#-------------------------------------------------------------------------------

set -e

# Parse flags
FORCE=false
ARGS=()
for arg in "$@"; do
  case "$arg" in
    -f|--force) FORCE=true ;;
    *) ARGS+=("$arg") ;;
  esac
done

if [ -n "${ARGS[1]}" ]; then
  BRANCH="${ARGS[1]}"
else
  BRANCH=$(getgitbranch --header="Select a branch to delete") &&
fi

# echo "BRANCH: ${BRANCH}"
BRANCHES=$(git ls-remote --heads origin ${BRANCH})
# echo "BRANCHES: ${BRANCHES}"

RESULT=$(echo "$BRANCHES" | grep "$BRANCH" | wc -l)
COUNT=$(echo ${RESULT//[[:blank:]]/})

if [[ "$COUNT" != "0" ]]; then
  CUT_BRANCHES=$(echo $BRANCHES | awk '{print $2}')
  # echo "CUT_BRANCHES: ${CUT_BRANCHES}"
  BRANCH_NAMES=$(echo $CUT_BRANCHES | sed 's/^refs\/heads\///g')
  # echo "BRANCH_NAMES: ${BRANCH_NAMES}"

  # Filter out protected branches from git config
  PROTECTED_EXACT=$(git config --get-all zdot-git.delremote.protected 2>/dev/null || true)
  PROTECTED_REGEX=$(git config --get-all zdot-git.delremote.protected-regex 2>/dev/null || true)
  FILTERED_NAMES="$BRANCH_NAMES"

  if [[ -n "$PROTECTED_EXACT" ]]; then
    while IFS= read -r pattern; do
      [[ -z "$pattern" ]] && continue
      FILTERED_NAMES=$(echo "$FILTERED_NAMES" | grep -vxF "$pattern" || true)
    done <<< "$PROTECTED_EXACT"
  fi

  if [[ -n "$PROTECTED_REGEX" ]]; then
    while IFS= read -r pattern; do
      [[ -z "$pattern" ]] && continue
      FILTERED_NAMES=$(echo "$FILTERED_NAMES" | grep -vE "$pattern" || true)
    done <<< "$PROTECTED_REGEX"
  fi

  is_protected() {
    local branch="$1"
    if [[ -n "$PROTECTED_EXACT" ]]; then
      while IFS= read -r pattern; do
        [[ -z "$pattern" ]] && continue
        [[ "$branch" == "$pattern" ]] && return 0
      done <<< "$PROTECTED_EXACT"
    fi
    if [[ -n "$PROTECTED_REGEX" ]]; then
      while IFS= read -r pattern; do
        [[ -z "$pattern" ]] && continue
        echo "$branch" | grep -qE "$pattern" && return 0
      done <<< "$PROTECTED_REGEX"
    fi
    return 1
  }

  DISPLAY_NAMES=$([[ "$FORCE" == true ]] && echo "$BRANCH_NAMES" || echo "$FILTERED_NAMES")

  if [[ -z "$DISPLAY_NAMES" ]]; then
    chalk -t "{blue  info } => No deletable branches matching {blueBright ${BRANCH}} (all matches are protected)"
  else
    deleteBranch=$(echo $DISPLAY_NAMES | fzf --header 'Delete remote branch (Press ESC to cancel)?') &&
    if is_protected "$deleteBranch"; then
      chalk -t "{yellow  warn } => {redBright ${deleteBranch}} is a protected branch. Are you sure you want to delete it? [y/N] \c"
      read -q CONFIRM || {
        chalk -t "\n{blue  info } => Aborted"
        exit 0
      }
      echo
    fi
    chalk -t "{blue  info } => Deleting remote branch {redBright ${deleteBranch}}" &&
    git push origin --delete ${deleteBranch}
  fi
else
  chalk -t "{blue  info } => No remote branches matching {blueBright ${BRANCH}}"
fi
