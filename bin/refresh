#!/usr/bin/env zsh
#
# refresh
# Git pull rebase on the current branch without a checkout
#-------------------------------------------------------------------------------

set -e

defaultBranch=$(git-default-branch)

if [[ "$(git-current-branch)" == "$defaultBranch" ]]; then
  # We are on main branch, just pull
  git pull origin "$defaultBranch";
else
  # Pull the latest on master without checkout
  git fetch origin $defaultBranch:$defaultBranch
  # Apply latest changes on current branch
  git rebase $defaultBranch
fi
